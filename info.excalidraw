    {
      "id": "ICayj0zHSTOn-DH_4_1KV",
      "type": "text",
      "x": 489.62339785573977,
      "y": -2469.772690914799,
      "width": 369.3797607421875,
      "height": 275,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
