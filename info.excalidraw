      "seed": 1437282203,
      "version": 733,
      "versionNonce": 295005077,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772102824966,
      "link": null,
      "locked": false,
      "text": "AWS\n\nA normal Linux server you control\n\nOn a VPS you can:\n    1. Use plain HTTP\n    2. Or force TLS 1.2\n    3. Use RSA certs\n    4. Keep certs stable\n    5. Avoid proxy layers",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AWS\n\nA normal Linux server you control\n\nOn a VPS you can:\n    1. Use plain HTTP\n    2. Or force TLS 1.2\n    3. Use RSA certs\n    4. Keep certs stable\n    5. Avoid proxy layers",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wNlYCJ7I_AfK0cQ0Cxdmy",
      "type": "text",
      "x": 1032.6584924298286,
      "y": -1170.04677151549,
      "width": 398.267822265625,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a8",
      "roundness": null,
      "seed": 1931465051,
      "version": 95,
      "versionNonce": 1868946709,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770299627131,
      "link": null,
      "locked": false,
      "text": "1. Dynamic certificates\n2. Load balancers\n3. Session reuse tricks\n4. Proxy chains",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. Dynamic certificates\n2. Load balancers\n3. Session reuse tricks\n4. Proxy chains",
      "autoResize": true,
      "lineHeight": 1.25
    },
