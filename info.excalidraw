      "updated": 1770304918901,
      "link": null,
      "locked": false,
      "text": "Quectel EC200U\n\n1. 4G LTE\n2. TCP / HTTP / HTTPS\n3. TLS (encryption)\n4. Certificate validation",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Quectel EC200U\n\n1. 4G LTE\n2. TCP / HTTP / HTTPS\n3. TLS (encryption)\n4. Certificate validation",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "7ZznTQvR1jQ1zTo9uD9YE",
      "type": "text",
      "x": -883.6167036366553,
      "y": -760.4814074558763,
      "width": 738.3237915039062,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a4",
      "roundness": null,
      "seed": 2038461621,
      "version": 387,
      "versionNonce": 880155931,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770298009234,
      "link": null,
      "locked": false,
      "text": "What EC200U supports well\n\n1. HTTP\n2. HTTPS with TLS 1.2\n3. RSA certificates\n4. Static servers\n5. Traditional web servers (Nginx, Apache)",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What EC200U supports well\n\n1. HTTP\n2. HTTPS with TLS 1.2\n3. RSA certificates\n4. Static servers\n5. Traditional web servers (Nginx, Apache)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_DwAO3bxRfmAiydyckObU",
      "type": "text",
      "x": 20.770460254582872,
      "y": -748.5707091437315,
      "width": 514.94384765625,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a5",
      "roundness": null,
      "seed": 1547767131,
      "version": 679,
      "versionNonce": 330800016,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770303875257,
      "link": null,
      "locked": false,
      "text": "What EC200U struggles with\n\n1. TLS 1.3\n2. Rapid certificate rotation\n3. Cloud proxy platforms\n3. Browser-optimized HTTPS\n4. Fancy cipher suites",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What EC200U struggles with\n\n1. TLS 1.3\n2. Rapid certificate rotation\n3. Cloud proxy platforms\n3. Browser-optimized HTTPS\n4. Fancy cipher suites",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "DTcTsWHkuhhUSsg34Hs6C",
      "type": "text",
      "x": -880.2255199480244,
      "y": -346.3035069623163,
      "width": 582.9837646484375,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
