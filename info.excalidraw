      "boundElements": [],
      "updated": 1770298003319,
      "link": null,
      "locked": false,
      "text": "ESP32-S3\n\n1. Runs your Arduino code\n2. Reads sensor\n3. Sends AT commands\n4. Has Wi-Fi / BLE\n5. Does NOT do HTTPS here",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ESP32-S3\n\n1. Runs your Arduino code\n2. Reads sensor\n3. Sends AT commands\n4. Has Wi-Fi / BLE\n5. Does NOT do HTTPS here",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
