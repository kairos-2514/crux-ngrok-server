      "versionNonce": 1609050720,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1770826715302,
      "link": null,
      "locked": false,
      "text": "1. sensor calibration\n    Offset & noise filtering\n    \n2. sampling stratergy\n    Fixed interval (e.g., every 1s / 5s)\n\n3. Local fail-safe rules\n    Cut off if:\n        a. Temp > threshold\n        b. Current spike\n4. Offline buffering\n    Store readings on SD card if no internet\n\n5. Firmware update strategy\n    OTA update",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. sensor calibration\n    Offset & noise filtering\n    \n2. sampling stratergy\n    Fixed interval (e.g., every 1s / 5s)\n\n3. Local fail-safe rules\n    Cut off if:\n        a. Temp > threshold\n        b. Current spike\n4. Offline buffering\n    Store readings on SD card if no internet\n\n5. Firmware update strategy\n    OTA update",
      "autoResize": true,
      "lineHeight": 1.25
    },
